<div id="report-frame" class="report-frame">
  <h3 class="report-frame__heading">Choose a year</h3>

  <div class="report-frame__actions">
    <% years.each do |year| %>
      <form action="<%= examples_reports_submit_year_path %>"
            method="post"
            data-erbswap-form="true"
            data-erbswap-target="report-frame"
            data-erbswap-swap="replace">
        <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
        <%= hidden_field_tag :year, year %>
        <button type="submit"
                class="button button--year"
                data-erbswap-loading-text="Checking <%= year %>...">
          Request <%= year %> Report
        </button>
      </form>
    <% end %>
  </div>

  <p class="report-frame__hint">
    Try them all. <strong>2025</strong> raises an error.
    <strong>2022</strong> has no data and shows the empty state.
    Notice how clicking any button hides the siblings &mdash; that's
    the single-flight CSS pattern, zero JS.
  </p>
</div>
