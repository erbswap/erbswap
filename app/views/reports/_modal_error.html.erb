<div id="report-frame" class="report-frame">
  <h3 class="report-frame__heading">Report request failed</h3>
  <div class="alert alert--error">
    <p><%= message.presence || "Please try again in a moment." %></p>
  </div>
  <p class="report-frame__hint">Close and reopen the modal to retry.</p>
</div>
